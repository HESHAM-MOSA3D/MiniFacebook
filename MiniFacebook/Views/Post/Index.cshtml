@model List<MiniFacebook.Models.Post>

@{
    ViewData["Title"] = "Feed";
}

<div class="card shadow-lg mb-4">
    <div class="card-body">
        <div class="d-flex align-items-center mb-3">
            <div class="user-avatar me-2">
                <i class="fas fa-user"></i>
            </div>
            <h5 class="mb-0">What's on your mind?</h5>
        </div>
        <textarea id="postInput" class="form-control mb-3" rows="3" placeholder="Write your post here..."></textarea>
        <div class="mb-3 d-flex align-items-center">
            <label class="btn btn-outline-secondary btn-sm mb-0 rounded-pill px-3">
                <i class="fas fa-image text-success"></i> Add Photo
                <input type="file" id="postImage" class="d-none" accept="image/*" onchange="document.getElementById('postImageName').innerText = this.files[0] ? this.files[0].name : '';" />
            </label>
            <span id="postImageName" class="ms-3 text-muted small fw-semibold"></span>
        </div>
        <button onclick="sendPost()" class="btn btn-primary w-100">
            <i class="fas fa-paper-plane"></i> Post
        </button>
    </div>
</div>

<div class="modal fade" id="likesModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-sm modal-dialog-scrollable">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header border-bottom-0 pb-0">
                <h6 class="modal-title fw-bold">Likes</h6>
                <button type="button" class="btn-close btn-sm" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="likesList" class="list-group list-group-flush">
                    <div class="text-center py-3 text-muted"><div class="spinner-border spinner-border-sm text-primary"></div></div>
                </div>
            </div>
        </div>
    </div>
</div>

<div id="posts">
    @foreach (var post in Model)
    {
        <div class="card shadow-lg" id="post-@post.Id">
            <div class="card-body">
                <div class="post-header">
                    <div class="d-flex align-items-center">
                        <a href="/profile/@post.User.UserName">
                            <img src="@(string.IsNullOrEmpty(post.User.ProfilePicture) ? "/images/default-avatar.jpeg" : post.User.ProfilePicture)" class="rounded-circle me-3 shadow-sm" width="40" height="40" style="object-fit: cover;" onerror="this.src='/images/default-avatar.jpeg';" />
                        </a>
                        <div>
                            <h6 class="mb-0">
                                <a href="/profile/@post.User.UserName" class="text-decoration-none text-dark hover-underline">
                                    @post.User.FullName
                                </a>
                            </h6>
                            <a href="/profile/@post.User.UserName/posts/@post.Id" class="text-decoration-none text-muted">
                                <small class="post-time hover-underline">
                                    <i class="far fa-clock"></i> @post.CreatedAt.ToString("MMM dd, yyyy hh:mm tt")
                                </small>
                            </a>
                        </div>
                    </div>
                    @if (User.Identity.Name == post.User.UserName)
                    {
                        <div>
                            <button onclick="editPost(@post.Id, '@post.Content.Replace("'", "\\'")', '@post.ImageUrl')" class="btn btn-sm btn-warning">
                                <i class="fas fa-edit"></i>
                            </button>
                            <button onclick="deletePost(@post.Id)" class="btn btn-sm btn-danger">
                                <i class="fas fa-trash"></i>
                            </button>
                        </div>
                    }
                </div>

                <p id="post-content-@post.Id" class="mt-3 post-content">@post.Content</p>

                @if (!string.IsNullOrEmpty(post.ImageUrl))
                {
                    <a href="/profile/@post.User.UserName/posts/@post.Id">
                        <img src="@post.ImageUrl" class="post-image hover-opacity" />
                    </a>
                }

                <div class="post-stats mt-3 d-flex align-items-center" style="font-size: 0.95rem;">
                    @if (post.Likes != null && post.Likes.Any())
                    {
                        var latestLike = post.Likes.OrderByDescending(l => l.CreatedAt).First();
                        int othersCount = post.Likes.Count - 1;
                        <span id="likes-count-@post.Id" class="me-3 cursor-pointer text-muted" onclick="showLikesModal(@post.Id)" style="cursor: pointer;">
                            <i class="fas fa-thumbs-up text-primary"></i>
                            @if (othersCount > 0)
                            {
                                <span><strong class="text-dark">@latestLike.User.FullName</strong> and <span class="count">@othersCount</span> others liked that</span>
                            }
                            else
                            {
                                <span><strong class="text-dark">@latestLike.User.FullName</strong> liked that</span>
                            }
                        </span>
                    }
                    else
                    {
                        <span id="likes-count-@post.Id" class="me-3 text-muted">
                            <i class="fas fa-thumbs-up"></i> <span class="count">0</span> Likes
                        </span>
                    }

                    <span id="comments-count-@post.Id" class="text-muted">
                        <i class="fas fa-comment"></i> <span class="count">@(post.Comments?.Count ?? 0)</span> Comments
                    </span>
                </div>

                <div class="post-actions">
                    <button class="btn btn-sm like-button @(post.Likes.Any(l => l.UserId == ViewBag.CurrentUserId) ? "active" : "btn-outline-primary")" onclick="toggleLike(@post.Id, null)">
                        <i class="fas fa-heart"></i> Like
                    </button>
                    <a href="/profile/@post.User.UserName/posts/@post.Id" class="btn btn-sm btn-outline-secondary">
                        <i class="far fa-comment"></i> Comment
                    </a>
                </div>

                <div id="comments-section-@post.Id" style="display: none;" class="mt-3">
                    <div id="comments-@post.Id" class="mb-3">
                        @foreach (var c in post.Comments)
                        {
                            <div id="comment-@c.Id" class="comment-item">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div class="d-flex align-items-start">
                                        <a href="/profile/@c.User.UserName" class="text-decoration-none">
                                            <img src="@(string.IsNullOrEmpty(c.User.ProfilePicture) ? "/images/default-avatar.jpeg" : c.User.ProfilePicture)" class="rounded-circle me-3 shadow-sm border" width="40" height="40" style="object-fit:cover;" onerror="this.src='/images/default-avatar.jpeg';" />
                                        </a>
                                        <div class="bg-light p-2 rounded">
                                            <a href="/profile/@c.User.UserName" class="text-decoration-none text-dark hover-underline">
                                                <strong>@c.User.FullName</strong>
                                            </a>
                                            <p id="comment-content-@c.Id" class="mb-0 mt-1">@c.Content</p>
                                            @if (!string.IsNullOrEmpty(c.ImageUrl))
                                            {
                                                <img src="@c.ImageUrl" class="post-image mt-2" style="max-width: 200px; border-radius: 8px;" />
                                            }
                                            <small class="text-muted mt-1 d-block" style="font-size: 0.75rem;">@c.CreatedAt.ToString("MMM dd, hh:mm tt")</small>
                                        </div>
                                    </div>
                                    @if (User.Identity.Name == c.User.UserName)
                                    {
                                        <div>
                                            <button onclick="editComment(@c.Id, @post.Id, '@c.Content.Replace("'", "\\'")')" class="btn btn-sm btn-warning">
                                                <i class="fas fa-edit"></i>
                                            </button>
                                            <button onclick="deleteComment(@c.Id, @post.Id)" class="btn btn-sm btn-danger">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>

                    <div class="input-group mb-2">
                        <input type="text" id="commentInput-@post.Id" class="form-control" placeholder="Write a comment..." />
                    </div>
                    <div class="input-group">
                        <input type="file" id="commentImage-@post.Id" class="form-control" accept="image/*" />
                        <button onclick="sendComment(@post.Id)" class="btn btn-primary">
                            <i class="fas fa-paper-plane"></i> Post
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<div class="modal fade" id="editPostModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Edit Post</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="editPostId" />
                <div class="mb-3">
                    <label class="form-label">Content</label>
                    <textarea id="editPostContent" class="form-control" rows="4"></textarea>
                </div>
                <div class="mb-3 text-center" id="editPostImagePreviewContainer" style="display: none;">
                    <img id="editPostImagePreview" src="" style="max-width: 100%; max-height: 200px; border-radius: 10px; object-fit: contain;" />
                    <small class="d-block text-muted mt-1">Current Image</small>
                    <div class="form-check d-flex justify-content-center mt-2">
                        <input class="form-check-input me-2" type="checkbox" id="removeExistingImage">
                        <label class="form-check-label text-danger fw-semibold" for="removeExistingImage">Remove this image</label>
                    </div>
                </div>
                <div class="mb-3 d-flex align-items-center">
                    <label class="btn btn-outline-secondary btn-sm mb-0 rounded-pill px-3">
                        <i class="fas fa-image text-success"></i> Replace Image
                        <input type="file" id="editPostImage" class="d-none" accept="image/*"
                               onchange="document.getElementById('editPostImageName').innerText = this.files[0] ? this.files[0].name : '';" />
                    </label>
                    <span id="editPostImageName" class="ms-3 text-muted small fw-semibold"></span>
                </div>

            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Discard</button>
                <button type="button" class="btn btn-primary" onclick="submitEditPost()">Save Changes</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="deletePostModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header text-white bg-danger">
                <h5 class="modal-title">Delete Post</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="deletePostId" />
                <p class="fs-5">Are you sure to delete this post?</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" onclick="confirmDeletePost()">Confirm</button>
            </div>
        </div>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.0/signalr.min.js"></script>
<script>
    function showNotification(message, type = 'success') {
    const notification = $(`
    <div class="toast-notification alert alert-${type} shadow-lg">
    <i class="fas fa-${type === 'success' ? 'check-circle' : 'exclamation-circle'}"></i>
    ${message}
    </div>
    `);
    $('body').append(notification);
    setTimeout(() => notification.fadeOut(() => notification.remove()), 3000);
    }

    function toggleComments(postId) {
    $(`#comments-section-${postId}`).slideToggle();
    }

    const connection = new signalR.HubConnectionBuilder()
    .withUrl("/socialHub")
    .build();

    connection.start().catch(err => console.error(err));

    connection.on("ReceivePost", function (user, content, imageUrl) {
    location.reload();
    });

    connection.on("ReceiveComment", function (postId, user, content, imageUrl, profilePic, userName) {
    const commentsDiv = $(`#comments-${postId}`);
    const newComment = `
    <div class="comment-item">
    <div class="d-flex justify-content-between align-items-start">
    <div class="d-flex align-items-start">
    <a href="/profile/${userName}" class="text-decoration-none">
    <img src="${profilePic || '/images/default-avatar.jpeg'}" class="rounded-circle me-3 shadow-sm border" width="40" height="40" style="object-fit:cover;" onerror="this.src='/images/default-avatar.jpeg';"/>
    </a>
    <div class="bg-light p-2 rounded">
    <a href="/profile/${userName}" class="text-decoration-none text-dark hover-underline">
    <strong>${user}</strong>
    </a>
    <p class="mb-0 mt-1">${content}</p>
    ${imageUrl ? `<img src="${imageUrl}" class="post-image mt-2" style="max-width: 200px; border-radius: 8px;" />` : ''}
    <small class="text-muted mt-1 d-block" style="font-size: 0.75rem;">Just now</small>
    </div>
    </div>
    </div>
    </div>
    `;
    commentsDiv.append(newComment);
    showNotification('New comment added!', 'success');
    });

    connection.on("PostUpdated", function (postId, content, imageUrl, user) {
    $(`#post-content-${postId}`).text(content);
    showNotification('Post updated successfully!', 'success');
    });

    connection.on("PostDeleted", function (postId) {
    $(`#post-${postId}`).fadeOut(() => $(this).remove());
    showNotification('Post deleted!', 'info');
    });

    connection.on("LikeToggled", function (postId, commentId, user, isLiked, likesCount) {
    if (postId) {
    $(`#likes-count-${postId}`).text(likesCount);
    const likeButton = $(`#post-${postId} .like-button`);
    if (isLiked) {
    likeButton.addClass('active');
    } else {
    likeButton.removeClass('active');
    }
    }
    });

    function sendPost() {
    const content = $("#postInput").val();
    if (!content.trim()) {
    showNotification('Please write something', 'warning');
    return;
    }

    const formData = new FormData();
    formData.append('content', content);
    const imageFile = $('#postImage')[0].files[0];
    if (imageFile) {
    formData.append('image', imageFile);
    }

    const btn = event.target;
    const originalText = btn.innerHTML;
    btn.innerHTML = '<span class="spinner"></span> Posting...';
    btn.disabled = true;

    fetch('/Post/Create', {
    method: 'POST',
    body: formData
    }).then(() => {
    $("#postInput").val('');
    $("#postImage").val('');
    location.reload();
    }).finally(() => {
    btn.innerHTML = originalText;
    btn.disabled = false;
    });
    }

    function editPost(postId, currentContent, currentImageUrl) {
    $("#editPostId").val(postId);
    $("#editPostContent").val(currentContent);
    $("#removeExistingImage").prop("checked", false);
    document.getElementById('editPostImageName').innerText = '';
    if (currentImageUrl) {
    $("#editPostImagePreview").attr("src", currentImageUrl);
    $("#editPostImagePreviewContainer").show();
    $("#editPostImageLabel").text("Replace Image");
    } else {
    $("#editPostImagePreviewContainer").hide();
    $("#editPostImageLabel").text("Add Image");
    }
    $("#editPostImage").val('');
    new bootstrap.Modal(document.getElementById('editPostModal')).show();
    }

    function submitEditPost() {
    const postId = $("#editPostId").val();
    const newContent = $("#editPostContent").val();
    if (!newContent.trim()) {
    showNotification('Post content cannot be empty', 'warning');
    return;
    }

    const formData = new FormData();
    formData.append('id', postId);
    formData.append('content', newContent);

    if ($("#removeExistingImage").is(':checked')) {
    formData.append('removeImage', true);
    }

    const imageFile = $('#editPostImage')[0].files[0];
    if (imageFile) {
    formData.append('image', imageFile);
    }

    fetch('/Post/UpdatePost', {
    method: 'POST',
    body: formData
    }).then(() => {
    const modal = bootstrap.Modal.getInstance(document.getElementById('editPostModal'));
    modal.hide();
    });
    }

    function deletePost(postId) {
    $("#deletePostId").val(postId);
    new bootstrap.Modal(document.getElementById('deletePostModal')).show();
    }

    function confirmDeletePost() {
    const postId = $("#deletePostId").val();
    fetch('/Post/DeletePost', {
    method: 'POST',
    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
    body: `id=${postId}`
    }).then(() => {
    const modal = bootstrap.Modal.getInstance(document.getElementById('deletePostModal'));
    modal.hide();
    });
    }

    function toggleLike(postId, commentId) {
    fetch('/Post/ToggleLike', {
    method: 'POST',
    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
    body: `postId=${postId}&commentId=${commentId}`
    });
    }

    function sendComment(postId) {
    const input = $(`#commentInput-${postId}`);
    const content = input.val();
    if (!content.trim()) {
    showNotification('Please write a comment', 'warning');
    return;
    }

    const formData = new FormData();
    formData.append('postId', postId);
    formData.append('content', content);
    const imageFile = $(`#commentImage-${postId}`)[0].files[0];
    if (imageFile) {
    formData.append('image', imageFile);
    }

    fetch('/Post/AddComment', {
    method: 'POST',
    body: formData
    }).then(() => {
    input.val('');
    $(`#commentImage-${postId}`).val('');
    showNotification('Comment added!', 'success');
    });
    }

    function editComment(commentId, postId, currentContent) {
    const newContent = prompt("Edit your comment:", currentContent);
    if (newContent && newContent.trim() && newContent !== currentContent) {
    fetch('/Post/UpdateComment', {
    method: 'POST',
    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
    body: `commentId=${commentId}&postId=${postId}&content=${encodeURIComponent(newContent)}`
    });
    }
    }

    function deleteComment(commentId, postId) {
    if (confirm("Are you sure you want to delete this comment?")) {
    fetch('/Post/DeleteComment', {
    method: 'POST',
    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
    body: `commentId=${commentId}&postId=${postId}`
    });
    }
    }
    
    function showLikesModal(postId) {
    fetch(`/Post/GetPostLikes?postId=${postId}`)
    .then(res => res.json())
    .then(data => {
    const list = document.getElementById('likesList');
    list.innerHTML = '';
    if(data.length === 0) {
    list.innerHTML = '<div class="text-center py-3 text-muted small">No likes yet</div>';
    } else {
    data.forEach(u => {
    list.innerHTML += `
    <a href="/profile/${u.username}" class="list-group-item list-group-item-action border-0 px-2 py-2 d-flex align-items-center rounded mb-1">
    <img src="${u.profilePicture}" class="rounded-circle me-3 shadow-sm border" width="35" height="35" style="object-fit:cover;" onerror="this.onerror=null; this.src='/images/default-avatar.jpeg';"/>
    <div>
    <div class="fw-bold text-dark" style="font-size:0.9rem;">${u.fullName}</div>
    </div>
    </a>
    `;
    });
    }
    new bootstrap.Modal(document.getElementById('likesModal')).show();
    });
    }
</script>